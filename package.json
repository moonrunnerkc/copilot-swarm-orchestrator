{
  "name": "swarm-orchestrator",
  "version": "5.0.0",
  "description": "Verification and governance layer for AI coding agents. Parallel execution with evidence-based quality gates.",
  "main": "dist/src/index.js",
  "bin": {
    "swarm": "dist/src/cli.js",
    "swarm-orchestrator": "dist/src/cli.js"
  },
  "files": [
    "dist/src/",
    "agents/",
    "config/",
    "plugin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('dist/src/cli.js', 0o755)\"",
    "build-plugin": "node scripts/build-plugin.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build && npm test",
    "test": "npm run build && mocha --recursive 'dist/test/**/*.test.js'",
    "test:ci": "mocha --recursive 'dist/test/**/*.test.js'",
    "start": "node dist/src/cli.js",
    "docker:build": "docker build -t swarm-orchestrator .",
    "docker:run": "docker run --rm --env-file .env swarm-orchestrator"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moonrunnerkc/swarm-orchestrator.git"
  },
  "keywords": [
    "orchestrator",
    "swarm",
    "parallel",
    "ai",
    "verification",
    "quality-gates",
    "copilot",
    "claude-code",
    "codex"
  ],
  "author": "Bradley R. Kinnard",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/moonrunnerkc/swarm-orchestrator/issues"
  },
  "homepage": "https://github.com/moonrunnerkc/swarm-orchestrator#readme",
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.10",
    "@types/react": "^18.2.79",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ink": "^4.4.1",
    "ink-spinner": "^5.0.0",
    "js-yaml": "^4.1.1",
    "react": "^18.2.0"
  }
}
